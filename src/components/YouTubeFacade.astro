---
interface Props {
  playlistId?: string;
  videoId: string;
  title?: string;
}

const { playlistId, videoId, title = "Video" } = Astro.props;
---

<div
  class="youtube-facade relative w-full aspect-video rounded-xl overflow-hidden cursor-pointer group"
  data-video-id={videoId}
>
  <img
    src={`https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`}
    alt={`Thumbnail de ${title}`}
    class="absolute inset-0 w-full h-full object-cover"
    loading="lazy"
    decoding="async"
    transition:name={ playlistId ? `playlist-${playlistId}` : `video-${videoId}` }
  />
  
  <div class="absolute inset-0 bg-black/20 group-hover:bg-black/10 transition-colors"></div>
  
  <button
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-16 h-16 md:w-20 md:h-20 bg-red-600 rounded-full flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform hover:bg-red-700"
    aria-label={`Reproducir ${title}`}
  >
    <svg class="w-8 h-8 md:w-10 md:h-10 text-white ml-1" viewBox="0 0 24 24" fill="currentColor">
      <path d="M8 5v14l11-7z"/>
    </svg>
  </button>
</div>

<script>
  document.querySelectorAll('.youtube-facade').forEach(facade => {
    facade.addEventListener('click', function() {
      const videoId = this.dataset.videoId;
      this.innerHTML = `<iframe 
        src="https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&enablejsapi=1" 
        class="w-full h-full rounded-xl"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
        allowfullscreen>
      </iframe>`;
    }, { once: true });
  });
</script>
